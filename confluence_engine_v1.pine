//@version=6
indicator("MNQ Confluence Engine v1.0", overlay=true, max_labels_count=500, max_lines_count=100)

// ── Inputs ────────────────────────────────────────────────────────────────────
i_useSR    = input.bool(true,  "Ativar SR Retest",               group="1. SR Break & Retest")
i_srLeft   = input.int(10,     "Pivot Esquerda",                 group="1. SR Break & Retest", minval=3)
i_srRight  = input.int(3,      "Pivot Direita",                  group="1. SR Break & Retest", minval=1)
i_useCross = input.bool(true,  "Ativar MACD Crossover",          group="2. MACD + EMA 200")
i_useExh   = input.bool(true,  "Ativar MACD Exhaustion",         group="2. MACD + EMA 200")
i_exhBars  = input.int(3,      "Barras p/ Exhaustion",           group="2. MACD + EMA 200", minval=2, maxval=6)
i_mFast    = input.int(12,     "MACD Fast",                      group="2. MACD + EMA 200")
i_mSlow    = input.int(26,     "MACD Slow",                      group="2. MACD + EMA 200")
i_mSig     = input.int(9,      "MACD Signal",                    group="2. MACD + EMA 200")
i_emaLen   = input.int(200,    "EMA Length",                     group="2. MACD + EMA 200")
i_useKZ    = input.bool(true,  "Filtro: Sessao 8h-15h SP",       group="3. Filtros")
i_useVWAP  = input.bool(true,  "Filtro: VWAP",                   group="3. Filtros")
i_useVol   = input.bool(false, "Filtro: Volume > Media",         group="3. Filtros")
i_volLen   = input.int(20,     "Volume - Periodo Media",         group="3. Filtros", minval=5)
i_cooldown = input.int(5,      "Cooldown entre sinais (barras)", group="3. Filtros", minval=1, maxval=50)
i_atrLen   = input.int(14,     "ATR Periodo",                    group="4. Niveis (SL / TP)")
i_slAtr    = input.float(1.0,  "Stop Loss (x ATR)",              group="4. Niveis (SL / TP)", step=0.25, minval=0.25)
i_tp1Atr   = input.float(1.0,  "Take Profit 1 (x ATR)",         group="4. Niveis (SL / TP)", step=0.25, minval=0.25)
i_tp2Atr   = input.float(2.0,  "Take Profit 2 (x ATR)",         group="4. Niveis (SL / TP)", step=0.25, minval=0.5)
i_showDash = input.bool(true,  "Dashboard (condicoes atuais)",   group="5. Visual")
i_showSR   = input.bool(true,  "Linhas SR",                      group="5. Visual")
i_showKZbg = input.bool(true,  "Background Sessao",              group="5. Visual")

// ── Indicators ────────────────────────────────────────────────────────────────
ema200                 = ta.ema(close, i_emaLen)
[macd_l, macd_s, hist] = ta.macd(close, i_mFast, i_mSlow, i_mSig)
vwap_v                 = ta.vwap(hlc3)
atr_v                  = ta.atr(i_atrLen)
vol_avg                = ta.sma(volume, i_volLen)
in_kz                  = not na(time(timeframe.period, "0800-1500", "America/Sao_Paulo"))

// ── Signal 1: MACD Crossover + EMA 200 ───────────────────────────────────────
cross_up   = ta.crossover(macd_l,  macd_s)
cross_down = ta.crossunder(macd_l, macd_s)
s1_long    = i_useCross and cross_up   and close > ema200
s1_short   = i_useCross and cross_down and close < ema200

// ── Signal 2: MACD Exhaustion ─────────────────────────────────────────────────
bull_exh = true
bear_exh = true
for i = 0 to i_exhBars - 1
    if hist[i] >= 0
        bull_exh := false
    if hist[i] <= 0
        bear_exh := false
    if i < i_exhBars - 1
        if math.abs(hist[i]) >= math.abs(hist[i + 1])
            bull_exh := false
            bear_exh := false

var bool prev_bull_exh = false
var bool prev_bear_exh = false
s2_long  = i_useExh and bull_exh and not prev_bull_exh
s2_short = i_useExh and bear_exh and not prev_bear_exh
prev_bull_exh := bull_exh
prev_bear_exh := bear_exh

// ── Signal 3: SR Break & Retest ───────────────────────────────────────────────
ph = ta.pivothigh(high, i_srLeft, i_srRight)
pl = ta.pivotlow(low,   i_srLeft, i_srRight)
var float last_ph = na
var float last_pl = na
var float sr_res  = na
var float sr_sup  = na
if not na(ph)
    last_ph := ph
if not na(pl)
    last_pl := pl
if not na(last_ph) and close[1] <= last_ph and close > last_ph
    sr_res := last_ph
if not na(last_pl) and close[1] >= last_pl and close < last_pl
    sr_sup := last_pl
sr_zone      = atr_v * 0.75
s3_long_raw  = i_useSR and not na(sr_res) and close > sr_res and low  < sr_res + sr_zone and close > open
s3_short_raw = i_useSR and not na(sr_sup) and close < sr_sup and high > sr_sup - sr_zone and close < open
s3_long      = s3_long_raw  and not s3_long_raw[1]
s3_short     = s3_short_raw and not s3_short_raw[1]

// ── Confluence Score ──────────────────────────────────────────────────────────
above_ema  = close > ema200
above_vwap = close > vwap_v
high_vol   = volume > vol_avg
macd_bull  = macd_l > macd_s

sc_long = 0
sc_long := sc_long + (s1_long    ? 2 : 0)
sc_long := sc_long + (s2_long    ? 2 : 0)
sc_long := sc_long + (s3_long    ? 2 : 0)
sc_long := sc_long + (in_kz      ? 1 : 0)
sc_long := sc_long + (above_vwap ? 1 : 0)
sc_long := sc_long + (above_ema  ? 1 : 0)
sc_long := sc_long + (high_vol   ? 1 : 0)
sc_long := sc_long + (hist > hist[1] ? 1 : 0)

sc_short = 0
sc_short := sc_short + (s1_short       ? 2 : 0)
sc_short := sc_short + (s2_short       ? 2 : 0)
sc_short := sc_short + (s3_short       ? 2 : 0)
sc_short := sc_short + (in_kz          ? 1 : 0)
sc_short := sc_short + (not above_vwap ? 1 : 0)
sc_short := sc_short + (not above_ema  ? 1 : 0)
sc_short := sc_short + (high_vol       ? 1 : 0)
sc_short := sc_short + (hist < hist[1] ? 1 : 0)

stars_long  = sc_long  >= 7 ? "★★★" : sc_long  >= 5 ? "★★" : sc_long  >= 3 ? "★" : ""
stars_short = sc_short >= 7 ? "★★★" : sc_short >= 5 ? "★★" : sc_short >= 3 ? "★" : ""

// ── Filters & Final Signal ───────────────────────────────────────────────────
kz_ok       = not i_useKZ   or in_kz
vwap_lng_ok = not i_useVWAP or above_vwap
vwap_sht_ok = not i_useVWAP or not above_vwap
vol_ok      = not i_useVol  or high_vol
raw_long    = s1_long  or s2_long  or s3_long
raw_short   = s1_short or s2_short or s3_short

var int last_sig_bar = -999
cooldown_ok = bar_index - last_sig_bar >= i_cooldown
sig_long    = raw_long  and kz_ok and vwap_lng_ok and vol_ok and stars_long  != "" and cooldown_ok
sig_short   = raw_short and kz_ok and vwap_sht_ok and vol_ok and stars_short != "" and cooldown_ok
if sig_long or sig_short
    last_sig_bar := bar_index

// ── Signal Labels — só em barras confirmadas (sem repaint) ────────────────────
f_p(p) => str.tostring(math.round(p, 1))

col_long_3  = color.new(#00C853,  0)
col_long_2  = color.new(#00C853, 45)
col_long_1  = color.new(#00C853, 68)
col_short_3 = color.new(#D50000,  0)
col_short_2 = color.new(#D50000, 45)
col_short_1 = color.new(#D50000, 68)

if sig_long and not na(atr_v) and barstate.isconfirmed
    col   = sc_long >= 7 ? col_long_3 : sc_long >= 5 ? col_long_2 : col_long_1
    sl_p  = close - atr_v * i_slAtr
    tp1_p = close + atr_v * i_tp1Atr
    tp2_p = close + atr_v * i_tp2Atr
    lbl   = stars_long + "  BUY\nSL " + f_p(sl_p) + "  |  TP1 " + f_p(tp1_p) + "  |  TP2 " + f_p(tp2_p)
    label.new(bar_index, low - atr_v * 0.4, lbl,
              color=col, textcolor=color.white,
              style=label.style_label_up, size=size.small)

if sig_short and not na(atr_v) and barstate.isconfirmed
    col   = sc_short >= 7 ? col_short_3 : sc_short >= 5 ? col_short_2 : col_short_1
    sl_p  = close + atr_v * i_slAtr
    tp1_p = close - atr_v * i_tp1Atr
    tp2_p = close - atr_v * i_tp2Atr
    lbl   = stars_short + "  SELL\nSL " + f_p(sl_p) + "  |  TP1 " + f_p(tp1_p) + "  |  TP2 " + f_p(tp2_p)
    label.new(bar_index, high + atr_v * 0.4, lbl,
              color=col, textcolor=color.white,
              style=label.style_label_down, size=size.small)

// ── Dashboard ─────────────────────────────────────────────────────────────────
f_yn(c) => c ? "[v]" : "[ ]"
f_lr(c) => c ? color.lime : color.red
f_lg(c) => c ? color.lime : color.gray

if i_showDash and barstate.islast
    var table dash = table.new(position.top_left, 2, 11, bgcolor=color.new(color.black, 70), border_width=1, frame_width=1, frame_color=color.gray)
    table.cell(dash, 0, 0,  "CONFLUENCIAS",                       text_color=color.white,       text_size=size.small, bgcolor=color.new(#1a237e, 30))
    table.cell(dash, 1, 0,  "STATUS",                             text_color=color.white,       text_size=size.small, bgcolor=color.new(#1a237e, 30))
    table.cell(dash, 0, 1,  f_yn(in_kz)      + " Sessao SP",     text_color=f_lg(in_kz),      text_size=size.tiny)
    table.cell(dash, 1, 1,  in_kz ? "8-15h ATIVO" : "FORA",      text_color=f_lg(in_kz),      text_size=size.tiny)
    table.cell(dash, 0, 2,  f_yn(above_ema)  + " EMA 200",       text_color=f_lr(above_ema),  text_size=size.tiny)
    table.cell(dash, 1, 2,  above_ema  ? "ACIMA" : "ABAIXO",     text_color=f_lr(above_ema),  text_size=size.tiny)
    table.cell(dash, 0, 3,  f_yn(above_vwap) + " VWAP",          text_color=f_lr(above_vwap), text_size=size.tiny)
    table.cell(dash, 1, 3,  above_vwap ? "ACIMA" : "ABAIXO",     text_color=f_lr(above_vwap), text_size=size.tiny)
    table.cell(dash, 0, 4,  f_yn(macd_bull)  + " MACD Dir.",     text_color=f_lr(macd_bull),  text_size=size.tiny)
    table.cell(dash, 1, 4,  macd_bull ? "BULLISH" : "BEARISH",   text_color=f_lr(macd_bull),  text_size=size.tiny)
    table.cell(dash, 0, 5,  f_yn(high_vol)   + " Volume",        text_color=f_lg(high_vol),   text_size=size.tiny)
    table.cell(dash, 1, 5,  high_vol ? "ALTO" : "NORMAL",        text_color=f_lg(high_vol),   text_size=size.tiny)
    table.cell(dash, 0, 6,  f_yn(s1_long or s1_short) + " MACD Cross", text_color=f_lg(s1_long or s1_short), text_size=size.tiny)
    table.cell(dash, 1, 6,  s1_long ? "LONG" : s1_short ? "SHORT" : "-", text_color=s1_long ? color.lime : s1_short ? color.red : color.gray, text_size=size.tiny)
    table.cell(dash, 0, 7,  f_yn(s2_long or s2_short) + " Exhaustion", text_color=f_lg(s2_long or s2_short), text_size=size.tiny)
    table.cell(dash, 1, 7,  s2_long ? "LONG" : s2_short ? "SHORT" : "-", text_color=s2_long ? color.lime : s2_short ? color.red : color.gray, text_size=size.tiny)
    table.cell(dash, 0, 8,  f_yn(s3_long or s3_short) + " SR Retest",  text_color=f_lg(s3_long or s3_short), text_size=size.tiny)
    table.cell(dash, 1, 8,  s3_long ? "LONG" : s3_short ? "SHORT" : "-", text_color=s3_long ? color.lime : s3_short ? color.red : color.gray, text_size=size.tiny)
    sc_cur = sig_long ? sc_long : sig_short ? sc_short : 0
    table.cell(dash, 0, 9,  "Score",                              text_color=color.white, text_size=size.tiny)
    table.cell(dash, 1, 9,  str.tostring(sc_cur) + "/10",        text_color=sc_cur >= 7 ? color.yellow : sc_cur >= 5 ? color.lime : color.gray, text_size=size.tiny)
    cur_txt = sig_long ? stars_long + " LONG" : sig_short ? stars_short + " SHORT" : "AGUARDANDO"
    cur_col = sig_long ? color.lime : sig_short ? color.red : color.gray
    table.cell(dash, 0, 10, "SINAL",                              text_color=color.white, text_size=size.small, bgcolor=color.new(#1a237e, 30))
    table.cell(dash, 1, 10, cur_txt,                              text_color=cur_col,     text_size=size.small, bgcolor=color.new(#1a237e, 30))

// ── Plots ─────────────────────────────────────────────────────────────────────
plot(ema200, "EMA 200", color=color.new(color.orange, 20), linewidth=2)
plot(vwap_v, "VWAP",   color=color.new(color.purple,  30), linewidth=1)
bgcolor(i_showKZbg and in_kz ? color.new(color.teal, 92) : na, title="Sessao BG")

if i_showSR and barstate.islast
    if not na(sr_res)
        line.new(bar_index - 50, sr_res, bar_index, sr_res, color=color.new(color.green, 40), style=line.style_dashed, width=1, extend=extend.right)
    if not na(sr_sup)
        line.new(bar_index - 50, sr_sup, bar_index, sr_sup, color=color.new(color.red,   40), style=line.style_dashed, width=1, extend=extend.right)
