//@version=6
indicator("MNQ Confluence Engine v1.0", overlay=true, max_labels_count=500, max_lines_count=100)

// ══════════════════════════════════════════════════════════════════════════════
// INPUTS
// ══════════════════════════════════════════════════════════════════════════════

// 1. SR Break & Retest
i_useSR    = input.bool(true,  "Ativar SR Retest",              group="1. SR Break & Retest")
i_srLeft   = input.int(10,     "Pivot Esquerda",                group="1. SR Break & Retest", minval=3)
i_srRight  = input.int(3,      "Pivot Direita",                 group="1. SR Break & Retest", minval=1)

// 2. MACD + EMA 200
i_useCross = input.bool(true,  "Ativar MACD Crossover",         group="2. MACD + EMA 200")
i_useExh   = input.bool(true,  "Ativar MACD Exhaustion",        group="2. MACD + EMA 200")
i_exhBars  = input.int(3,      "Barras p/ Exhaustion",          group="2. MACD + EMA 200", minval=2, maxval=6)
i_mFast    = input.int(12,     "MACD Fast",                     group="2. MACD + EMA 200")
i_mSlow    = input.int(26,     "MACD Slow",                     group="2. MACD + EMA 200")
i_mSig     = input.int(9,      "MACD Signal",                   group="2. MACD + EMA 200")
i_emaLen   = input.int(200,    "EMA Length",                    group="2. MACD + EMA 200")

// 3. Filtros
i_useKZ    = input.bool(true,  "Filtro: Kill Zone 9:30-11:30 ET", group="3. Filtros")
i_useVWAP  = input.bool(true,  "Filtro: VWAP",                  group="3. Filtros")
i_useVol   = input.bool(false, "Filtro: Volume > Media",        group="3. Filtros")
i_volLen   = input.int(20,     "Volume - Periodo Media",        group="3. Filtros")

// 4. Stats
i_evalBars = input.int(30,     "Barras p/ avaliar resultado",   group="4. Stats", minval=5, maxval=200)
i_atrLen   = input.int(14,     "ATR Periodo",                   group="4. Stats")
i_slAtr    = input.float(1.0,  "Stop Loss (x ATR)",             group="4. Stats", step=0.25, minval=0.25)
i_tpAtr    = input.float(2.0,  "Take Profit (x ATR)",           group="4. Stats", step=0.25, minval=0.5)

// 5. Visual
i_showDash  = input.bool(true, "Dashboard (condicoes atuais)",  group="5. Visual")
i_showStats = input.bool(true, "Stats Box (performance)",       group="5. Visual")
i_showSR    = input.bool(true, "Linhas SR",                     group="5. Visual")
i_showKZbg  = input.bool(true, "Background Kill Zone",         group="5. Visual")

// ══════════════════════════════════════════════════════════════════════════════
// INDICADORES BASE
// ══════════════════════════════════════════════════════════════════════════════

ema200              = ta.ema(close, i_emaLen)
[macd_l, macd_s, hist] = ta.macd(close, i_mFast, i_mSlow, i_mSig)
vwap_v              = ta.vwap(hlc3)
atr_v               = ta.atr(i_atrLen)
vol_avg             = ta.sma(volume, i_volLen)
in_kz               = not na(time(timeframe.period, "0930-1130", "America/New_York"))

// ══════════════════════════════════════════════════════════════════════════════
// SINAL 1 — MACD CROSSOVER + EMA 200
// ══════════════════════════════════════════════════════════════════════════════

cross_up   = ta.crossover(macd_l,  macd_s)
cross_down = ta.crossunder(macd_l, macd_s)
s1_long  = i_useCross and cross_up   and close > ema200
s1_short = i_useCross and cross_down and close < ema200

// ══════════════════════════════════════════════════════════════════════════════
// SINAL 2 — MACD EXHAUSTION (predict)
// Histograma negativo com barras diminuindo = vendedores esgotando (long)
// Histograma positivo com barras diminuindo = compradores esgotando (short)
// ══════════════════════════════════════════════════════════════════════════════

bull_exh = true
bear_exh = true

for i = 0 to i_exhBars - 1
    if hist[i] >= 0
        bull_exh := false
    if hist[i] <= 0
        bear_exh := false
    if i < i_exhBars - 1
        if math.abs(hist[i]) >= math.abs(hist[i + 1])
            bull_exh := false
            bear_exh := false

// Disparar apenas na primeira barra do padrao (evita repeticao)
var bool prev_bull_exh = false
var bool prev_bear_exh = false

s2_long  = i_useExh and bull_exh and not prev_bull_exh
s2_short = i_useExh and bear_exh and not prev_bear_exh

prev_bull_exh := bull_exh
prev_bear_exh := bear_exh

// ══════════════════════════════════════════════════════════════════════════════
// SINAL 3 — SR BREAK & RETEST
// Detecta quando resistencia quebrada vira suporte (e vice-versa)
// ══════════════════════════════════════════════════════════════════════════════

ph = ta.pivothigh(high, i_srLeft, i_srRight)
pl = ta.pivotlow(low,   i_srLeft, i_srRight)

var float last_ph   = na
var float last_pl   = na
var float sr_res    = na  // resistencia quebrada -> novo suporte
var float sr_sup    = na  // suporte quebrado -> nova resistencia

if not na(ph)
    last_ph := ph
if not na(pl)
    last_pl := pl

// Detectar rompimentos
if not na(last_ph) and close[1] <= last_ph and close > last_ph
    sr_res := last_ph

if not na(last_pl) and close[1] >= last_pl and close < last_pl
    sr_sup := last_pl

// Retest: preco retorna ao nivel rompido
sr_zone = atr_v * 0.75

s3_long_raw  = i_useSR and not na(sr_res) and close > sr_res and
               low < sr_res + sr_zone and close > open

s3_short_raw = i_useSR and not na(sr_sup) and close < sr_sup and
               high > sr_sup - sr_zone and close < open

// Disparar apenas uma vez por retest
s3_long  = s3_long_raw  and not s3_long_raw[1]
s3_short = s3_short_raw and not s3_short_raw[1]

// ══════════════════════════════════════════════════════════════════════════════
// SCORE DE CONFLUENCIA
// ══════════════════════════════════════════════════════════════════════════════

above_ema  = close > ema200
above_vwap = close > vwap_v
high_vol   = volume > vol_avg
macd_bull  = macd_l > macd_s

// Pontuacao Long (max = 10)
sc_long = 0
sc_long := sc_long + (s1_long  ? 2 : 0)  // sinal primario vale 2
sc_long := sc_long + (s2_long  ? 2 : 0)
sc_long := sc_long + (s3_long  ? 2 : 0)
sc_long := sc_long + (in_kz    ? 1 : 0)  // filtros valem 1
sc_long := sc_long + (above_vwap ? 1 : 0)
sc_long := sc_long + (above_ema  ? 1 : 0)
sc_long := sc_long + (high_vol   ? 1 : 0)
sc_long := sc_long + (hist > hist[1] ? 1 : 0)  // momentum melhorando

// Pontuacao Short (max = 10)
sc_short = 0
sc_short := sc_short + (s1_short      ? 2 : 0)
sc_short := sc_short + (s2_short      ? 2 : 0)
sc_short := sc_short + (s3_short      ? 2 : 0)
sc_short := sc_short + (in_kz         ? 1 : 0)
sc_short := sc_short + (not above_vwap ? 1 : 0)
sc_short := sc_short + (not above_ema  ? 1 : 0)
sc_short := sc_short + (high_vol       ? 1 : 0)
sc_short := sc_short + (hist < hist[1] ? 1 : 0)

// Qualidade do sinal
qual_long  = sc_long  >= 7 ? "A+" : sc_long  >= 5 ? "A" : sc_long  >= 3 ? "B" : ""
qual_short = sc_short >= 7 ? "A+" : sc_short >= 5 ? "A" : sc_short >= 3 ? "B" : ""

// Filtros obrigatorios
kz_ok       = not i_useKZ   or in_kz
vwap_lng_ok = not i_useVWAP or above_vwap
vwap_sht_ok = not i_useVWAP or not above_vwap
vol_ok      = not i_useVol  or high_vol

// Sinal final
raw_long  = s1_long  or s2_long  or s3_long
raw_short = s1_short or s2_short or s3_short

sig_long  = raw_long  and kz_ok and vwap_lng_ok and vol_ok and qual_long  != ""
sig_short = raw_short and kz_ok and vwap_sht_ok and vol_ok and qual_short != ""

// ══════════════════════════════════════════════════════════════════════════════
// STATS TRACKING
// Avalia cada sinal historico: TP ou SL foi atingido primeiro?
// ══════════════════════════════════════════════════════════════════════════════

var int[]    st_bar  = array.new_int()
var int[]    st_dir  = array.new_int()
var float[]  st_sl   = array.new_float()
var float[]  st_tp   = array.new_float()
var string[] st_qual = array.new_string()
var int[]    st_exp  = array.new_int()

var int w_ap = 0, l_ap = 0
var int w_a  = 0, l_a  = 0
var int w_b  = 0, l_b  = 0

// Registrar novos sinais
if sig_long and not na(atr_v)
    array.push(st_bar,  bar_index)
    array.push(st_dir,  1)
    array.push(st_sl,   close - atr_v * i_slAtr)
    array.push(st_tp,   close + atr_v * i_tpAtr)
    array.push(st_qual, qual_long)
    array.push(st_exp,  bar_index + i_evalBars)

if sig_short and not na(atr_v)
    array.push(st_bar,  bar_index)
    array.push(st_dir,  -1)
    array.push(st_sl,   close + atr_v * i_slAtr)
    array.push(st_tp,   close - atr_v * i_tpAtr)
    array.push(st_qual, qual_short)
    array.push(st_exp,  bar_index + i_evalBars)

// Avaliar sinais pendentes — nunca na barra de entrada, só nas barras seguintes
idx = 0
while idx < array.size(st_bar)
    sig_b = array.get(st_bar,  idx)
    d     = array.get(st_dir,  idx)
    sl    = array.get(st_sl,   idx)
    tp    = array.get(st_tp,   idx)
    q     = array.get(st_qual, idx)
    exp   = array.get(st_exp,  idx)

    resolved = false
    won      = false

    if sig_b < bar_index
        if d == 1
            if low  <= sl
                resolved := true
                won      := false
            else if high >= tp
                resolved := true
                won      := true
        else
            if high >= sl
                resolved := true
                won      := false
            else if low  <= tp
                resolved := true
                won      := true

        if not resolved and bar_index >= exp
            resolved := true
            won      := false

    if resolved
        if q == "A+"
            if won
                w_ap += 1
            else
                l_ap += 1
        else if q == "A"
            if won
                w_a += 1
            else
                l_a += 1
        else
            if won
                w_b += 1
            else
                l_b += 1
        array.remove(st_bar,  idx)
        array.remove(st_dir,  idx)
        array.remove(st_sl,   idx)
        array.remove(st_tp,   idx)
        array.remove(st_qual, idx)
        array.remove(st_exp,  idx)
    else
        idx += 1

// ══════════════════════════════════════════════════════════════════════════════
// LABELS NO CHART
// ══════════════════════════════════════════════════════════════════════════════

// LONG  → verde: A+=vivo | A=médio | B=pálido
col_long_ap  = color.new(#00C853,  0)
col_long_a   = color.new(#00C853, 45)
col_long_b   = color.new(#00C853, 72)
// SHORT → vermelho: A+=vivo | A=médio | B=pálido
col_short_ap = color.new(#D50000,  0)
col_short_a  = color.new(#D50000, 45)
col_short_b  = color.new(#D50000, 72)

f_p(p) => str.tostring(math.round(p, 1))

if sig_long and not na(atr_v)
    col  = qual_long == "A+" ? col_long_ap : qual_long == "A" ? col_long_a : col_long_b
    sl_p = close - atr_v * i_slAtr
    tp_p = close + atr_v * i_tpAtr
    lbl  = qual_long + " L  " + f_p(close) + "\nSL " + f_p(sl_p) + "  TP " + f_p(tp_p)
    label.new(bar_index, low - atr_v * 0.4, lbl,
         color=col, textcolor=color.white,
         style=label.style_label_up, size=size.small)

if sig_short and not na(atr_v)
    col  = qual_short == "A+" ? col_short_ap : qual_short == "A" ? col_short_a : col_short_b
    sl_p = close + atr_v * i_slAtr
    tp_p = close - atr_v * i_tpAtr
    lbl  = qual_short + " S  " + f_p(close) + "\nSL " + f_p(sl_p) + "  TP " + f_p(tp_p)
    label.new(bar_index, high + atr_v * 0.4, lbl,
         color=col, textcolor=color.white,
         style=label.style_label_down, size=size.small)

// ══════════════════════════════════════════════════════════════════════════════
// DASHBOARD — CONDICOES ATUAIS (canto superior esquerdo)
// ══════════════════════════════════════════════════════════════════════════════

f_yn(c) => c ? "[v]" : "[ ]"
f_lr(c) => c ? color.lime : color.red
f_lg(c) => c ? color.lime : color.gray

if i_showDash and barstate.islast
    var table dash = table.new(position.top_left, 2, 11,
         bgcolor=color.new(color.black, 70),
         border_width=1, frame_width=1, frame_color=color.gray)

    // Header
    table.cell(dash, 0, 0, "CONFLUENCIAS",
         text_color=color.white, text_size=size.small,
         bgcolor=color.new(#1a237e, 30))
    table.cell(dash, 1, 0, "STATUS",
         text_color=color.white, text_size=size.small,
         bgcolor=color.new(#1a237e, 30))

    // Kill Zone
    table.cell(dash, 0, 1, f_yn(in_kz) + " Kill Zone",
         text_color=f_lg(in_kz), text_size=size.tiny)
    table.cell(dash, 1, 1, in_kz ? "ATIVO" : "FORA",
         text_color=f_lg(in_kz), text_size=size.tiny)

    // EMA 200
    table.cell(dash, 0, 2, f_yn(above_ema) + " EMA 200",
         text_color=f_lr(above_ema), text_size=size.tiny)
    table.cell(dash, 1, 2, above_ema ? "ACIMA" : "ABAIXO",
         text_color=f_lr(above_ema), text_size=size.tiny)

    // VWAP
    table.cell(dash, 0, 3, f_yn(above_vwap) + " VWAP",
         text_color=f_lr(above_vwap), text_size=size.tiny)
    table.cell(dash, 1, 3, above_vwap ? "ACIMA" : "ABAIXO",
         text_color=f_lr(above_vwap), text_size=size.tiny)

    // MACD direcao
    table.cell(dash, 0, 4, f_yn(macd_bull) + " MACD Dir.",
         text_color=f_lr(macd_bull), text_size=size.tiny)
    table.cell(dash, 1, 4, macd_bull ? "BULLISH" : "BEARISH",
         text_color=f_lr(macd_bull), text_size=size.tiny)

    // Volume
    table.cell(dash, 0, 5, f_yn(high_vol) + " Volume",
         text_color=f_lg(high_vol), text_size=size.tiny)
    table.cell(dash, 1, 5, high_vol ? "ALTO" : "NORMAL",
         text_color=f_lg(high_vol), text_size=size.tiny)

    // MACD Cross
    table.cell(dash, 0, 6, f_yn(s1_long or s1_short) + " MACD Cross",
         text_color=f_lg(s1_long or s1_short), text_size=size.tiny)
    table.cell(dash, 1, 6,
         s1_long ? "LONG" : s1_short ? "SHORT" : "-",
         text_color=s1_long ? color.lime : s1_short ? color.red : color.gray,
         text_size=size.tiny)

    // Exhaustion
    table.cell(dash, 0, 7, f_yn(s2_long or s2_short) + " Exhaustion",
         text_color=f_lg(s2_long or s2_short), text_size=size.tiny)
    table.cell(dash, 1, 7,
         s2_long ? "LONG" : s2_short ? "SHORT" : "-",
         text_color=s2_long ? color.lime : s2_short ? color.red : color.gray,
         text_size=size.tiny)

    // SR Retest
    table.cell(dash, 0, 8, f_yn(s3_long or s3_short) + " SR Retest",
         text_color=f_lg(s3_long or s3_short), text_size=size.tiny)
    table.cell(dash, 1, 8,
         s3_long ? "LONG" : s3_short ? "SHORT" : "-",
         text_color=s3_long ? color.lime : s3_short ? color.red : color.gray,
         text_size=size.tiny)

    // Score
    sc_cur = sig_long ? sc_long : sig_short ? sc_short : 0
    table.cell(dash, 0, 9, "Score",
         text_color=color.white, text_size=size.tiny)
    table.cell(dash, 1, 9, str.tostring(sc_cur) + "/10",
         text_color=sc_cur >= 7 ? color.yellow : sc_cur >= 5 ? color.lime : color.gray,
         text_size=size.tiny)

    // Sinal atual
    cur_txt = sig_long ? qual_long + " LONG" : sig_short ? qual_short + " SHORT" : "AGUARDANDO"
    cur_col = sig_long ? color.lime : sig_short ? color.red : color.gray
    table.cell(dash, 0, 10, "SINAL",
         text_color=color.white, text_size=size.small,
         bgcolor=color.new(#1a237e, 30))
    table.cell(dash, 1, 10, cur_txt,
         text_color=cur_col, text_size=size.small,
         bgcolor=color.new(#1a237e, 30))

// ══════════════════════════════════════════════════════════════════════════════
// STATS BOX — PERFORMANCE HISTORICA (canto superior direito)
// ══════════════════════════════════════════════════════════════════════════════

f_wr(w, l) =>
    t = w + l
    t > 0 ? str.tostring(math.round(w / t * 100, 1)) + "%  " +
            str.tostring(w) + "W / " + str.tostring(l) + "L" : "sem dados"

f_wr_col(w, l) =>
    t = w + l
    t == 0 ? color.gray : w / t >= 0.5 ? color.lime : color.red

if i_showStats and barstate.islast
    var table stats = table.new(position.top_right, 2, 6,
         bgcolor=color.new(color.black, 70),
         border_width=1, frame_width=1, frame_color=color.gray)

    sl_str = str.tostring(i_slAtr) + "R SL / " + str.tostring(i_tpAtr) + "R TP"
    table.cell(stats, 0, 0, "WIN RATE  (" + sl_str + ")",
         text_color=color.white, text_size=size.small,
         bgcolor=color.new(#1a237e, 30))
    table.cell(stats, 1, 0, str.tostring(i_evalBars) + " barras",
         text_color=color.gray, text_size=size.tiny,
         bgcolor=color.new(#1a237e, 30))

    table.cell(stats, 0, 1, "A+  (7-10 pts)",
         text_color=color.yellow, text_size=size.small)
    table.cell(stats, 1, 1, f_wr(w_ap, l_ap),
         text_color=f_wr_col(w_ap, l_ap), text_size=size.small)

    table.cell(stats, 0, 2, "A   (5-6 pts)",
         text_color=color.lime, text_size=size.small)
    table.cell(stats, 1, 2, f_wr(w_a, l_a),
         text_color=f_wr_col(w_a, l_a), text_size=size.small)

    table.cell(stats, 0, 3, "B   (3-4 pts)",
         text_color=color.aqua, text_size=size.small)
    table.cell(stats, 1, 3, f_wr(w_b, l_b),
         text_color=f_wr_col(w_b, l_b), text_size=size.small)

    w_all = w_ap + w_a + w_b
    l_all = l_ap + l_a + l_b
    table.cell(stats, 0, 4, "TOTAL",
         text_color=color.white, text_size=size.small,
         bgcolor=color.new(#1a237e, 50))
    table.cell(stats, 1, 4, f_wr(w_all, l_all),
         text_color=f_wr_col(w_all, l_all), text_size=size.small,
         bgcolor=color.new(#1a237e, 50))

    pending = array.size(st_bar)
    table.cell(stats, 0, 5, "Em avaliacao",
         text_color=color.gray, text_size=size.tiny)
    table.cell(stats, 1, 5, str.tostring(pending) + " sinais",
         text_color=color.gray, text_size=size.tiny)

// ══════════════════════════════════════════════════════════════════════════════
// PLOTS BASE
// ══════════════════════════════════════════════════════════════════════════════

plot(ema200, "EMA 200", color=color.new(color.orange, 20), linewidth=2)
plot(vwap_v, "VWAP",   color=color.new(color.purple,  30), linewidth=1)

bgcolor(i_showKZbg and in_kz ? color.new(color.teal, 92) : na, title="Kill Zone BG")

// SR Lines (apenas o nivel mais recente de cada)
if i_showSR and barstate.islast
    if not na(sr_res)
        line.new(bar_index - 50, sr_res, bar_index, sr_res,
             color=color.new(color.green, 40), style=line.style_dashed, width=1,
             extend=extend.right)
    if not na(sr_sup)
        line.new(bar_index - 50, sr_sup, bar_index, sr_sup,
             color=color.new(color.red, 40), style=line.style_dashed, width=1,
             extend=extend.right)
