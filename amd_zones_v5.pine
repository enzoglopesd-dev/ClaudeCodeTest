//@version=6
indicator("AMD + FVG [MNQ] v5", overlay=true, max_boxes_count=200, max_lines_count=100, max_labels_count=200)

// ══════════════════════════════════════════════════════
// INPUTS — AMD LOGIC
// ══════════════════════════════════════════════════════
int   acc_bars     = input.int  (30,   "Accumulation Length",          minval=5,  maxval=100,  group="AMD Logic")
float acc_rng_pct  = input.float(0.05, "Accumulation Range Max %",      minval=0.01, step=0.01, group="AMD Logic", tooltip="% of price. Ex: 0.05 = 0.05% of ~29400 ≈ 15 pts")
float man_sweep    = input.float(3.0,  "Min spike distance (pts)",      minval=0.5, step=0.25,  group="AMD Logic")
int   search_win   = input.int  (10,   "Max Search Window (bars)",      minval=2,  maxval=30,   group="AMD Logic", tooltip="Max bars after CHoCH to find FVG")
float fvg_atr_mult = input.float(0.5,  "Min FVG Gap (ATR Multiplier)",  minval=0.1, step=0.1,   group="AMD Logic")

// ══════════════════════════════════════════════════════
// INPUTS — TRADE SETTINGS
// ══════════════════════════════════════════════════════
int   atr_len      = input.int  (14,   "ATR Length",                    minval=5,  maxval=50,   group="Trade Settings")
float atr_sl_mult  = input.float(2.0,  "ATR SL Multiplier",             minval=0.5, step=0.25,  group="Trade Settings")
float rr_ratio     = input.float(2.0,  "Reward-to-Risk Ratio",          minval=0.5, step=0.5,   group="Trade Settings")
bool  show_accum   = input.bool (true, "Show Accumulation/Manipulation zones", group="Trade Settings")
bool  show_zones   = input.bool (true, "Show SL/TP zones",               group="Trade Settings")
bool  show_mid     = input.bool (true, "Show FVG midpoint line",         group="Trade Settings")

// ══════════════════════════════════════════════════════
// INPUTS — SESSIONS
// ══════════════════════════════════════════════════════
bool  use_ny_sess  = input.bool (true,  "New York Session  (08:00-17:00 EST)", group="Sessions")
bool  use_lon_sess = input.bool (false, "London Session    (03:00-12:00 EST)", group="Sessions")
bool  use_tok_sess = input.bool (false, "Tokyo Session     (19:00-04:00 EST)", group="Sessions")

// ══════════════════════════════════════════════════════
// INPUTS — ALERTS
// ══════════════════════════════════════════════════════
bool  alr_man      = input.bool (true, "Alert: Manipulation detected",  group="Alerts")
bool  alr_fvg      = input.bool (true, "Alert: FVG identified",         group="Alerts")
bool  alr_dist     = input.bool (true, "Alert: Distribution starts",    group="Alerts")
bool  alr_tp       = input.bool (true, "Alert: TP reached",             group="Alerts")

// ══════════════════════════════════════════════════════
// COMPUTED HELPERS
// ══════════════════════════════════════════════════════
atr_val = ta.atr(atr_len)

// Session filter — if none selected, allow all hours
is_ny  = not na(time(timeframe.period, "0800-1700", "America/New_York"))
is_lon = not na(time(timeframe.period, "0300-1200", "Europe/London"))
is_tok = not na(time(timeframe.period, "1900-0400", "America/New_York"))
any_sess = use_ny_sess or use_lon_sess or use_tok_sess
in_session = not any_sess or (use_ny_sess and is_ny) or (use_lon_sess and is_lon) or (use_tok_sess and is_tok)

// Range tightness (% of price)
r_hi          = ta.highest(high, acc_bars)
r_lo          = ta.lowest (low,  acc_bars)
acc_range_abs = close * acc_rng_pct / 100.0
tight         = (r_hi - r_lo) <= acc_range_abs
fvg_min_abs   = atr_val * fvg_atr_mult

// ══════════════════════════════════════════════════════
// STATE MACHINE
// 0=idle | 1=accumulating | 2=manipulation (multi-bar)
// 3=post-CHoCH (find FVG) | 4=fvg-active (wait fill)
// ══════════════════════════════════════════════════════
var int   st          = 0
var float acc_hi      = na
var float acc_lo      = na
var int   acc_st      = 0
var int   man_dir     = 0     // -1=bearish spike (above) | 1=bullish spike (below)
var int   man_idx     = 0
var int   choch_idx   = 0
var float man_extreme = na    // highest high (bear) or lowest low (bull) reached during manipulation
var float ifvg_top    = na
var float ifvg_bot    = na
var float entry_lvl   = na
var float sl_lvl      = na
var float tp_lvl      = na
var bool  dist_on     = false
var bool  tp_hit      = false
var box   b_acc       = na
var box   b_man       = na
var box   b_ifvg      = na
var box   b_dist      = na
var box   b_sl        = na
var box   b_tp_zone   = na
var line  l_mid       = na
var line  l_entry     = na

// ══════════════════════════════════════════════════════
// DAILY RESET
// ══════════════════════════════════════════════════════
if ta.change(time("D")) != 0 and st != 0
    st      := 0
    dist_on := false
    tp_hit  := false

// ══════════════════════════════════════════════════════
// STATE 0 → 1: IDLE → ACCUMULATING
// Trigger when price consolidates tightly within session
// ══════════════════════════════════════════════════════
if st == 0 and tight and in_session
    st     := 1
    acc_hi := r_hi
    acc_lo := r_lo
    acc_st := bar_index - acc_bars + 1
    b_acc  := box.new(acc_st, acc_hi, bar_index, acc_lo, border_color=show_accum ? color.new(#FFD700, 20) : color.new(color.white, 100), bgcolor=show_accum ? color.new(#FFD700, 82) : color.new(color.white, 100), border_width=1, text=show_accum ? "ACCUM" : "", text_color=show_accum ? color.new(#B8860B, 0) : color.new(color.white, 100), text_size=size.tiny, text_halign=text.align_left, text_valign=text.align_bottom)

// ══════════════════════════════════════════════════════
// STATE 1: ACCUMULATING
// Watch for a spike outside the range → begin manipulation tracking
// ══════════════════════════════════════════════════════
else if st == 1
    box.set_right(b_acc, bar_index)

    // Bearish manipulation: any bar spikes ABOVE the range (stop hunt on buy-side)
    if high >= acc_hi + man_sweep
        st          := 2
        man_dir     := -1
        man_idx     := bar_index
        man_extreme := high
        b_man       := box.new(bar_index, high, bar_index, acc_hi, border_color=show_accum ? color.new(#FF4444, 10) : color.new(color.white, 100), bgcolor=show_accum ? color.new(#FF4444, 72) : color.new(color.white, 100), border_width=1, text=show_accum ? "MANIP ▲" : "", text_color=show_accum ? color.new(#CC0000, 0) : color.new(color.white, 100), text_size=size.tiny, text_halign=text.align_left, text_valign=text.align_top)
        if alr_man
            alert("AMD | Bearish Manipulation — spike to " + str.tostring(high, "#.##"), alert.freq_once_per_bar)

    // Bullish manipulation: any bar spikes BELOW the range (stop hunt on sell-side)
    else if low <= acc_lo - man_sweep
        st          := 2
        man_dir     := 1
        man_idx     := bar_index
        man_extreme := low
        b_man       := box.new(bar_index, acc_lo, bar_index, low, border_color=show_accum ? color.new(#FF4444, 10) : color.new(color.white, 100), bgcolor=show_accum ? color.new(#FF4444, 72) : color.new(color.white, 100), border_width=1, text=show_accum ? "MANIP ▼" : "", text_color=show_accum ? color.new(#CC0000, 0) : color.new(color.white, 100), text_size=size.tiny, text_halign=text.align_left, text_valign=text.align_bottom)
        if alr_man
            alert("AMD | Bullish Manipulation — spike to " + str.tostring(low, "#.##"), alert.freq_once_per_bar)

    else if tight
        // Still consolidating — update boundaries
        acc_hi := r_hi
        acc_lo := r_lo
        box.set_top   (b_acc, acc_hi)
        box.set_bottom(b_acc, acc_lo)

    else if (bar_index - acc_st) > acc_bars * 4
        // Range expanded without a spike — reset
        st := 0
        box.delete(b_acc)

// ══════════════════════════════════════════════════════
// STATE 2: MANIPULATION (multi-bar tracking)
// Track the most extreme point. Transition to State 3 on CHoCH:
// CHoCH = price CLOSES BACK INSIDE the accumulation range.
// This is the key change vs. v4: spike + close can be on SEPARATE candles.
// ══════════════════════════════════════════════════════
else if st == 2
    // Expand manipulation box to track the full spike extent
    if man_dir == -1
        man_extreme := math.max(man_extreme, high)
        box.set_top(b_man, man_extreme)
    else
        man_extreme := math.min(man_extreme, low)
        box.set_bottom(b_man, man_extreme)
    box.set_right(b_man, bar_index)

    // CHoCH: price closes back inside the accumulation range
    choch = (man_dir == -1 and close <= acc_hi) or (man_dir == 1 and close >= acc_lo)

    if choch
        st        := 3
        choch_idx := bar_index

    // Timeout: spike never reversed — false signal, reset
    else if (bar_index - man_idx) > search_win * 3
        st := 0

// ══════════════════════════════════════════════════════
// STATE 3: POST-CHoCH — search for FVG
// The FVG (3-bar imbalance) forms during the reversal from the spike.
// Look within search_win bars of the CHoCH confirmation bar.
// ══════════════════════════════════════════════════════
else if st == 3
    box.set_right(b_man, bar_index)
    bars_since = bar_index - choch_idx

    if bars_since >= 2 and bars_since <= search_win
        // Bearish FVG: gap between bar[2] low and current bar high
        // bar[2].low > bar[0].high means a downward gap — bearish imbalance
        if man_dir == -1 and low[2] > high and (low[2] - high) >= fvg_min_abs
            st       := 4
            dist_on  := false
            tp_hit   := false
            ifvg_top := low[2]
            ifvg_bot := high
            ifvg_mid  = (ifvg_top + ifvg_bot) / 2
            b_ifvg   := box.new(bar_index - 2, ifvg_top, bar_index + 40, ifvg_bot, border_color=color.new(#FF8C00, 0), bgcolor=color.new(#FF8C00, 65), border_width=1, text="FVG ▼", text_color=color.new(#FF8C00, 0), text_size=size.tiny, text_halign=text.align_right, text_valign=text.align_center)
            if show_mid
                l_mid := line.new(bar_index - 2, ifvg_mid, bar_index + 40, ifvg_mid, color=color.new(#FF8C00, 0), style=line.style_dashed, width=1)
            if alr_fvg
                alert("AMD | Bearish FVG: " + str.tostring(ifvg_top, "#.##") + " → " + str.tostring(ifvg_bot, "#.##"), alert.freq_once_per_bar)

        // Bullish FVG: gap between bar[2] high and current bar low
        // bar[2].high < bar[0].low means an upward gap — bullish imbalance
        else if man_dir == 1 and high[2] < low and (low - high[2]) >= fvg_min_abs
            st       := 4
            dist_on  := false
            tp_hit   := false
            ifvg_top := low
            ifvg_bot := high[2]
            ifvg_mid  = (ifvg_top + ifvg_bot) / 2
            b_ifvg   := box.new(bar_index - 2, ifvg_top, bar_index + 40, ifvg_bot, border_color=color.new(#FF8C00, 0), bgcolor=color.new(#FF8C00, 65), border_width=1, text="FVG ▲", text_color=color.new(#FF8C00, 0), text_size=size.tiny, text_halign=text.align_right, text_valign=text.align_center)
            if show_mid
                l_mid := line.new(bar_index - 2, ifvg_mid, bar_index + 40, ifvg_mid, color=color.new(#FF8C00, 0), style=line.style_dashed, width=1)
            if alr_fvg
                alert("AMD | Bullish FVG: " + str.tostring(ifvg_bot, "#.##") + " → " + str.tostring(ifvg_top, "#.##"), alert.freq_once_per_bar)

    else if bars_since > search_win
        // FVG not found in time — reset cycle
        st := 0

// ══════════════════════════════════════════════════════
// STATE 4: FVG ACTIVE — wait for price to fill it
// Fill = price enters the FVG zone → this is the ENTRY
// Entry is at FVG edge nearest to the incoming price (conservative)
// SL: ATR × multiplier beyond entry
// TP: SL × RR ratio in the distribution direction
// ══════════════════════════════════════════════════════
else if st == 4
    box.set_right(b_ifvg, bar_index + 5)
    if show_mid and not na(l_mid)
        line.set_x2(l_mid, bar_index + 5)

    // Price enters the FVG zone
    fvg_filled = man_dir == -1 ? (high >= ifvg_bot and low <= ifvg_top) : (low <= ifvg_top and high >= ifvg_bot)

    // ── Distribution start on first FVG fill ─────────
    if fvg_filled and not dist_on
        dist_on   := true
        sl_size    = atr_val * atr_sl_mult
        // Entry at the FVG edge nearest to incoming price
        entry_lvl := man_dir == -1 ? ifvg_bot : ifvg_top
        sl_lvl    := man_dir == -1 ? entry_lvl + sl_size : entry_lvl - sl_size
        tp_lvl    := man_dir == -1 ? entry_lvl - sl_size * rr_ratio : entry_lvl + sl_size * rr_ratio

        b_dist := box.new(bar_index, high, bar_index, low, border_color=color.new(#26a69a, 30), bgcolor=color.new(#26a69a, 88), border_width=1, text="DIST  0 pts", text_color=color.new(#26a69a, 0), text_size=size.small, text_halign=text.align_left, text_valign=man_dir == -1 ? text.align_bottom : text.align_top)

        if show_zones
            // SL zone — purple, above entry (bear) / below entry (bull)
            b_sl      := box.new(bar_index, man_dir == -1 ? sl_lvl : entry_lvl, bar_index + 60, man_dir == -1 ? entry_lvl : sl_lvl, border_color=color.new(#9C27B0, 10), bgcolor=color.new(#9C27B0, 68), border_width=1, text="SL  " + str.tostring(math.round(sl_size), "#") + " pts", text_color=color.new(#CE93D8, 0), text_size=size.tiny, text_halign=text.align_right, text_valign=text.align_center)
            // TP zone — green, below entry (bear) / above entry (bull)
            b_tp_zone := box.new(bar_index, man_dir == -1 ? entry_lvl : tp_lvl, bar_index + 60, man_dir == -1 ? tp_lvl : entry_lvl, border_color=color.new(#00E676, 10), bgcolor=color.new(#00E676, 68), border_width=1, text="TP  " + str.tostring(math.round(sl_size * rr_ratio), "#") + " pts", text_color=color.new(#69F0AE, 0), text_size=size.tiny, text_halign=text.align_right, text_valign=text.align_center)
            // Entry line — white
            l_entry   := line.new(bar_index, entry_lvl, bar_index + 60, entry_lvl, color=color.new(color.white, 20), style=line.style_solid, width=1)

        if alr_dist
            alert("AMD | " + (man_dir == -1 ? "BEARISH" : "BULLISH") + " — Entry " + str.tostring(entry_lvl, "#.##") + " | SL " + str.tostring(math.round(sl_size), "#") + " pts | TP " + str.tostring(math.round(sl_size * rr_ratio), "#") + " pts", alert.freq_once_per_bar)

    // ── Extend distribution box ───────────────────────
    if dist_on
        box.set_right (b_dist, bar_index)
        box.set_top   (b_dist, math.max(box.get_top   (b_dist), high))
        box.set_bottom(b_dist, math.min(box.get_bottom(b_dist), low ))
        dist_pts = math.round(math.abs(box.get_top(b_dist) - box.get_bottom(b_dist)))
        box.set_text  (b_dist, "DIST  " + str.tostring(dist_pts) + " pts")

        // TP reached
        if not tp_hit
            tp_reached = man_dir == -1 ? low <= tp_lvl : high >= tp_lvl
            if tp_reached
                tp_hit := true
                label.new(bar_index, tp_lvl, "TP HIT  " + str.tostring(dist_pts) + " pts", yloc=yloc.price, style=man_dir == -1 ? label.style_label_up : label.style_label_down, color=color.new(#26a69a, 0), textcolor=color.white, size=size.normal)
                if show_zones and not na(b_tp_zone)
                    box.set_right(b_tp_zone, bar_index)
                    if not na(l_entry)
                        line.set_x2(l_entry, bar_index)
                if alr_tp
                    alert("AMD | TP reached — " + str.tostring(dist_pts) + " pts captured!", alert.freq_once_per_bar)

    // ── Invalidation: close beyond FVG = trade failed ─
    if dist_on
        invalidated = man_dir == -1 ? close > ifvg_top : close < ifvg_bot
        if invalidated
            st      := 0
            dist_on := false
            tp_hit  := false
            if show_zones
                if not na(b_sl)
                    box.set_right(b_sl, bar_index)
                if not na(b_tp_zone)
                    box.set_right(b_tp_zone, bar_index)
                if not na(l_entry)
                    line.set_x2(l_entry, bar_index)

    // ── Timeout: FVG never filled ─────────────────────
    if not dist_on and (bar_index - choch_idx) > search_win * 6
        st := 0
