//@version=6
indicator("AMD + IFVG [MNQ] v4", overlay=true, max_boxes_count=200, max_lines_count=100, max_labels_count=200)

// ══════════════════════════════════════════════════════
// INPUTS
// ══════════════════════════════════════════════════════
int   acc_bars      = input.int  (10,   "Min consolidation bars",     minval=3,  maxval=60,   group="Accumulation")
float acc_range     = input.float(10.0, "Max range size (pts)",        minval=1.0, step=0.5,  group="Accumulation")
float man_sweep     = input.float(3.0,  "Min spike distance (pts)",    minval=0.5, step=0.25, group="Manipulation")
int   ifvg_max      = input.int  (8,    "Max bars to detect IFVG",     minval=2,  maxval=20,  group="IFVG")
float ifvg_min      = input.float(2.0,  "Min IFVG size (pts)",         minval=0.5, step=0.25, group="IFVG")
int   ifvg_fill_tmo = input.int  (60,   "Max bars waiting IFVG fill",  minval=10, maxval=200, group="IFVG")
bool  show_mid      = input.bool (true, "Show IFVG midpoint line",      group="IFVG")
bool  show_zones    = input.bool (true, "Show SL/TP zones",             group="Trade Zones")
float sl_pts        = input.float(15.0, "Stop Loss size (pts)",         minval=1.0, step=0.5,  group="Trade Zones")
float rr_ratio      = input.float(2.0,  "Reward-to-Risk ratio",         minval=0.5, step=0.5,  group="Trade Zones")
bool  alr_man       = input.bool (true, "Alert: Manipulation detected", group="Alerts")
bool  alr_ifvg      = input.bool (true, "Alert: IFVG identified",      group="Alerts")
bool  alr_dist      = input.bool (true, "Alert: Distribution starts",   group="Alerts")
bool  alr_tp        = input.bool (true, "Alert: TP reached",            group="Alerts")

// ══════════════════════════════════════════════════════
// STATE  0=idle | 1=accumulating | 2=manipulation | 3=distribution
// ══════════════════════════════════════════════════════
var int   st          = 0
var float acc_hi      = na
var float acc_lo      = na
var int   acc_st      = 0
var int   man_dir     = 0       // 1=bull (spike below) | -1=bear (spike above)
var int   man_idx     = 0
var float man_extreme = na
var float ifvg_top    = na
var float ifvg_bot    = na
var float entry_lvl   = na
var float sl_lvl      = na
var float tp_lvl      = na
var bool  dist_on     = false
var bool  tp_hit      = false
var box   b_acc       = na
var box   b_man       = na
var box   b_ifvg      = na
var box   b_dist      = na
var box   b_sl        = na
var box   b_tp_zone   = na
var line  l_mid       = na
var line  l_entry     = na

// ══════════════════════════════════════════════════════
// HELPERS
// ══════════════════════════════════════════════════════
r_hi  = ta.highest(high, acc_bars)
r_lo  = ta.lowest (low,  acc_bars)
tight = (r_hi - r_lo) <= acc_range

// ══════════════════════════════════════════════════════
// DAILY RESET
// ══════════════════════════════════════════════════════
if ta.change(time("D")) != 0 and st != 0
    st      := 0
    dist_on := false
    tp_hit  := false

// ══════════════════════════════════════════════════════
// STATE 0: IDLE
// ══════════════════════════════════════════════════════
if st == 0 and tight
    st     := 1
    acc_hi := r_hi
    acc_lo := r_lo
    acc_st := bar_index - acc_bars + 1
    b_acc  := box.new(acc_st, acc_hi, bar_index, acc_lo, border_color=color.new(#FFD700, 20), bgcolor=color.new(#FFD700, 82), border_width=1, text="ACCUM", text_color=color.new(#B8860B, 0), text_size=size.tiny, text_halign=text.align_left, text_valign=text.align_bottom)

// ══════════════════════════════════════════════════════
// STATE 1: ACCUMULATING
// Manipulation: wick closes back inside AND wick >= body (strong rejection)
// ══════════════════════════════════════════════════════
else if st == 1
    box.set_right(b_acc, bar_index)

    upper_wick = high - math.max(open, close)
    lower_wick = math.min(open, close) - low
    body_size  = math.abs(close - open)

    // BEARISH manipulation
    if high >= acc_hi + man_sweep and close <= acc_hi and upper_wick >= body_size
        st          := 2
        man_dir     := -1
        man_idx     := bar_index
        man_extreme := high
        b_man       := box.new(bar_index, high, bar_index, acc_hi, border_color=color.new(#FF4444, 10), bgcolor=color.new(#FF4444, 72), border_width=1, text="MANIP", text_color=color.new(#CC0000, 0), text_size=size.tiny, text_halign=text.align_left, text_valign=text.align_top)
        if alr_man
            alert("AMD | Bearish Manipulation — spike to " + str.tostring(high, "#.##"), alert.freq_once_per_bar)

    // BULLISH manipulation
    else if low <= acc_lo - man_sweep and close >= acc_lo and lower_wick >= body_size
        st          := 2
        man_dir     := 1
        man_idx     := bar_index
        man_extreme := low
        b_man       := box.new(bar_index, acc_lo, bar_index, low, border_color=color.new(#FF4444, 10), bgcolor=color.new(#FF4444, 72), border_width=1, text="MANIP", text_color=color.new(#CC0000, 0), text_size=size.tiny, text_halign=text.align_left, text_valign=text.align_bottom)
        if alr_man
            alert("AMD | Bullish Manipulation — spike to " + str.tostring(low, "#.##"), alert.freq_once_per_bar)

    else if tight
        acc_hi := r_hi
        acc_lo := r_lo
        box.set_top   (b_acc, acc_hi)
        box.set_bottom(b_acc, acc_lo)

    else if (bar_index - acc_st) > acc_bars * 4
        st := 0
        box.delete(b_acc)

// ══════════════════════════════════════════════════════
// STATE 2: MANIPULATION — searching for IFVG
// ══════════════════════════════════════════════════════
else if st == 2
    box.set_right(b_man, bar_index)
    bars_since = bar_index - man_idx

    if bars_since >= 2 and bars_since <= ifvg_max
        // Bearish IFVG: low[2] > high
        if man_dir == -1 and low[2] > high and (low[2] - high) >= ifvg_min
            st       := 3
            dist_on  := false
            tp_hit   := false
            ifvg_top := low[2]
            ifvg_bot := high
            ifvg_mid  = (ifvg_top + ifvg_bot) / 2
            b_ifvg   := box.new(bar_index - 2, ifvg_top, bar_index + 40, ifvg_bot, border_color=color.new(#FF8C00, 0), bgcolor=color.new(#FF8C00, 65), border_width=1, text="IFVG", text_color=color.new(#FF8C00, 0), text_size=size.tiny, text_halign=text.align_right, text_valign=text.align_center)
            if show_mid
                l_mid := line.new(bar_index - 2, ifvg_mid, bar_index + 40, ifvg_mid, color=color.new(#FF8C00, 0), style=line.style_dashed, width=1)
            if alr_ifvg
                alert("AMD | Bearish IFVG: " + str.tostring(ifvg_top, "#.##") + " to " + str.tostring(ifvg_bot, "#.##"), alert.freq_once_per_bar)

        // Bullish IFVG: high[2] < low
        else if man_dir == 1 and high[2] < low and (low - high[2]) >= ifvg_min
            st       := 3
            dist_on  := false
            tp_hit   := false
            ifvg_top := low
            ifvg_bot := high[2]
            ifvg_mid  = (ifvg_top + ifvg_bot) / 2
            b_ifvg   := box.new(bar_index - 2, ifvg_top, bar_index + 40, ifvg_bot, border_color=color.new(#FF8C00, 0), bgcolor=color.new(#FF8C00, 65), border_width=1, text="IFVG", text_color=color.new(#FF8C00, 0), text_size=size.tiny, text_halign=text.align_right, text_valign=text.align_center)
            if show_mid
                l_mid := line.new(bar_index - 2, ifvg_mid, bar_index + 40, ifvg_mid, color=color.new(#FF8C00, 0), style=line.style_dashed, width=1)
            if alr_ifvg
                alert("AMD | Bullish IFVG: " + str.tostring(ifvg_bot, "#.##") + " to " + str.tostring(ifvg_top, "#.##"), alert.freq_once_per_bar)

    else if bars_since > ifvg_max
        st := 0

// ══════════════════════════════════════════════════════
// STATE 3: IFVG CONFIRMED — wait for fill → distribution
// Distribution ends ONLY on IFVG violation (close past IFVG),
// NOT on consolidation — captures the full move.
// ══════════════════════════════════════════════════════
else if st == 3
    box.set_right(b_ifvg, bar_index + 5)
    if show_mid and not na(l_mid)
        line.set_x2(l_mid, bar_index + 5)

    ifvg_filled = man_dir == -1 ? (high >= ifvg_bot and low <= ifvg_top) : (low <= ifvg_top and high >= ifvg_bot)

    // ── Distribution starts on first IFVG fill ────────────────
    if ifvg_filled and not dist_on
        dist_on   := true
        // Entry: conservative edge of IFVG nearest to price
        entry_lvl := man_dir == -1 ? ifvg_bot : ifvg_top
        sl_lvl    := man_dir == -1 ? entry_lvl + sl_pts : entry_lvl - sl_pts
        tp_lvl    := man_dir == -1 ? entry_lvl - sl_pts * rr_ratio : entry_lvl + sl_pts * rr_ratio

        b_dist    := box.new(bar_index, high, bar_index, low, border_color=color.new(#26a69a, 30), bgcolor=color.new(#26a69a, 88), border_width=1, text="DIST  0 pts", text_color=color.new(#26a69a, 0), text_size=size.small, text_halign=text.align_left, text_valign=man_dir == -1 ? text.align_bottom : text.align_top)

        if show_zones
            // SL zone — purple, above entry (bearish) / below entry (bullish)
            b_sl      := box.new(bar_index, man_dir == -1 ? sl_lvl : entry_lvl, bar_index + 60, man_dir == -1 ? entry_lvl : sl_lvl, border_color=color.new(#9C27B0, 10), bgcolor=color.new(#9C27B0, 68), border_width=1, text="SL  " + str.tostring(sl_pts, "#") + " pts", text_color=color.new(#CE93D8, 0), text_size=size.tiny, text_halign=text.align_right, text_valign=text.align_center)
            // TP zone — green, below entry (bearish) / above entry (bullish)
            b_tp_zone := box.new(bar_index, man_dir == -1 ? entry_lvl : tp_lvl, bar_index + 60, man_dir == -1 ? tp_lvl : entry_lvl, border_color=color.new(#00E676, 10), bgcolor=color.new(#00E676, 68), border_width=1, text="TP  " + str.tostring(math.round(sl_pts * rr_ratio), "#") + " pts", text_color=color.new(#69F0AE, 0), text_size=size.tiny, text_halign=text.align_right, text_valign=text.align_center)
            // Entry line — white, marks the trade entry price
            l_entry   := line.new(bar_index, entry_lvl, bar_index + 60, entry_lvl, color=color.new(color.white, 20), style=line.style_solid, width=1)

        if alr_dist
            alert("AMD | " + (man_dir == -1 ? "BEARISH" : "BULLISH") + " — Entry " + str.tostring(entry_lvl, "#.##") + " | SL " + str.tostring(sl_pts, "#") + " pts | TP " + str.tostring(math.round(sl_pts * rr_ratio), "#") + " pts", alert.freq_once_per_bar)

    // ── Extend distribution box each bar ─────────────────────
    if dist_on
        box.set_right (b_dist, bar_index)
        box.set_top   (b_dist, math.max(box.get_top   (b_dist), high))
        box.set_bottom(b_dist, math.min(box.get_bottom(b_dist), low ))
        dist_pts = math.round(math.abs(box.get_top(b_dist) - box.get_bottom(b_dist)))
        box.set_text  (b_dist, "DIST  " + str.tostring(dist_pts) + " pts")

        // TP reached
        if not tp_hit
            tp_reached = man_dir == -1 ? low <= tp_lvl : high >= tp_lvl
            if tp_reached
                tp_hit := true
                label.new(bar_index, tp_lvl, "TP HIT  " + str.tostring(dist_pts) + " pts", yloc=yloc.price, style=man_dir == -1 ? label.style_label_up : label.style_label_down, color=color.new(#26a69a, 0), textcolor=color.white, size=size.normal)
                // Freeze TP zone right edge at hit bar
                if show_zones and not na(b_tp_zone)
                    box.set_right(b_tp_zone, bar_index)
                    if not na(l_entry)
                        line.set_x2(l_entry, bar_index)
                if alr_tp
                    alert("AMD | TP reached — " + str.tostring(dist_pts) + " pts captured!", alert.freq_once_per_bar)

    // ── INVALIDATION: close beyond IFVG = trade failed ───────
    if dist_on
        invalidated = man_dir == -1 ? close > ifvg_top : close < ifvg_bot
        if invalidated
            st      := 0
            dist_on := false
            tp_hit  := false
            // Freeze zone boxes at invalidation bar
            if show_zones
                if not na(b_sl)
                    box.set_right(b_sl, bar_index)
                if not na(b_tp_zone)
                    box.set_right(b_tp_zone, bar_index)
                if not na(l_entry)
                    line.set_x2(l_entry, bar_index)

    // Timeout: IFVG never filled → reset
    if not dist_on and (bar_index - man_idx) > ifvg_fill_tmo
        st := 0
